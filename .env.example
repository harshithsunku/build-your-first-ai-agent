# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# Any OpenAI-compatible endpoint works (OpenAI, OpenRouter, LiteLLM, local Ollama).
# Every notebook loads this file automatically (falls back to existing env vars).

# --- OpenAI ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o-mini

# --- TLS / firewall ---
# Set to false ONLY behind a TLS-intercepting firewall/proxy where HTTPS cert
# verification fails. The notebooks then pass a no-verify httpx client to the
# OpenAI SDK. Leave it true (the default) on any normal network.
VERIFY_SSL=true

# --- OpenRouter (example) ---
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-your-key-here
# MODEL=openai/gpt-4o-mini

# --- Local Ollama (example; tool-calling needs a capable model) ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL=qwen2.5:7b
