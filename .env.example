# Copy this file to `.env` and fill in your own values.
#   cp .env.example .env
#
# Any OpenAI-compatible endpoint works (OpenAI, OpenRouter, LiteLLM, local Ollama).
# Notebooks 05-06 load this file automatically; for the others, export the same vars.

# --- OpenAI ---
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your-key-here
MODEL=gpt-4o-mini

# --- OpenRouter (example) ---
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-your-key-here
# MODEL=openai/gpt-4o-mini

# --- Local Ollama (example; tool-calling needs a capable model) ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL=qwen2.5:7b
